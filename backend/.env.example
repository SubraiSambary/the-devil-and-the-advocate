# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it contains secrets

# 'local' = Ollama on your machine (free, unlimited)
# 'cloud' = Groq API (for public deployment)
MODE=local

# Only needed when MODE=cloud
GROQ_API_KEY=

# Ollama settings (used when MODE=local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Debate settings
MAX_DEBATE_ROUNDS=6
MIN_WORDS_PER_TURN=40
MAX_WORDS_PER_TURN=120